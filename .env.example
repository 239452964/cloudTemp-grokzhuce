# freemail / cloudflare_temp_email 配置
# WORKER_DOMAIN 不要带 https://
WORKER_DOMAIN=your-worker.workers.dev
# cloudflare_temp_email 填站点密码；旧 freemail 填 JWT
FREEMAIL_TOKEN=your-password-or-jwt
# 邮箱后缀：auto=服务端默认；或具体域名如 example.com（控制台可自动拉取）
FREEMAIL_DOMAIN=auto
# auto | cf_temp | freemail
FREEMAIL_API_STYLE=auto

# Turnstile 验证配置
# 如果不填则使用本地 Turnstile Solver（http://127.0.0.1:5072）
YESCAPTCHA_KEY=
SOLVER_URL=http://127.0.0.1:5072
SOLVER_BROWSER=camoufox
# 建议 4~8：与注册并发匹配（并发约 ≤ SOLVER_THREADS*2）
SOLVER_THREADS=4
SOLVER_HOST=127.0.0.1
SOLVER_PORT=5072
SOLVER_DEBUG=0
# SSO 后后台换 token / 协议 / NSFW 线程数（建议 8~16）
ENRICH_WORKERS=12

# Web 控制台
UI_HOST=127.0.0.1
UI_PORT=3333

# ---------- sub2api（HTTP 导入到 Grok 分组）----------
# Web 地址，不要带末尾 /
SUB2API_URL=http://127.0.0.1:9898
# 导入目标分组：必须与 sub2api 后台「Grok」分组一致
SUB2API_GROK_GROUP_ID=23
SUB2API_GROK_GROUP_NAME=grok
# 管理员账号：仅保存在本地 .env，导入时通过 HTTP Admin API 登录
UPSTREAM_URL=http://127.0.0.1:9898
UPSTREAM_ADMIN_EMAIL=admin@example.com
UPSTREAM_ADMIN_PASSWORD=your-admin-password
